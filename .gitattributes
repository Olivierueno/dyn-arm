# Keep Linux/WSL-run files as LF regardless of the host OS or git autocrlf setting.
* text=auto
.gitattributes text eol=lf
.gitignore text eol=lf
LICENSE text eol=lf
*.sh   text eol=lf
*.bash text eol=lf
*.py   text eol=lf
*.yaml text eol=lf
*.xacro text eol=lf
*.md   text eol=lf
*.xml  text eol=lf
# Windows-only helpers stay CRLF
*.ps1  text eol=crlf
*.bat  text eol=crlf
# Binaries
*.stl  binary
*.xlsx binary
*.jpg  binary
*.jpeg binary
*.png  binary
